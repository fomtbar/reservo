# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=reservo
POSTGRES_PASSWORD=reservo_dev
POSTGRES_DB=reservo_dev
DATABASE_URL="postgresql://reservo:reservo_dev@reservo-db-dev:5432/reservo_dev"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://reservo-redis-dev:6379"

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:4000

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ──────────────────────────────────────────────────────────────
# Must be exactly 32 characters
MASTER_KEY=dev-master-key-32-chars-exactly!!

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4001/api
